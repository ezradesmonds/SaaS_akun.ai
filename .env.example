# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=openrouter/auto

# Mayar
MAYAR_API_KEY=your-mayar-api-key
MAYAR_BASE_URL=https://api.mayar.id/hl/v1
MAYAR_WEBHOOK_SECRET=required-shared-secret
MAYAR_DEFAULT_MOBILE=081234567890
MAYAR_DASHBOARD_URL=https://web.mayar.id

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_ACCESS_TOKEN=optional-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=optional-default-phone-number-id
# Optional JSON or comma pairs for webhook business resolution:
# {"phone_number_id_or_customer_wa_id":"business-uuid"} or phone:business-uuid,phone2:business-uuid
WHATSAPP_BUSINESS_MAP={}

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
